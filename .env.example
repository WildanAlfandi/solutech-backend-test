# Database
# Ganti sesuai kredensial PostgreSQL lokal Anda.
# Format: postgresql://[user]:[password]@[host]:[port]/[database]
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/solutech_test"

# JWT
# Secret key untuk signing JWT token. Gunakan string acak yang panjang untuk production.
JWT_SECRET="ganti-dengan-string-rahasia-yang-panjang-dan-acak"